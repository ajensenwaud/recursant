# =============================================================================
# Recursant Platform - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.sample .env
# =============================================================================

# -----------------------------------------------------------------------------
# LLM Provider Configuration
# -----------------------------------------------------------------------------

# Which LLM provider the demo agents use: anthropic, openai, google, openrouter, or moonshot
LLM_PROVIDER=openrouter

# Model identifier — for openrouter use "openrouter/auto" (OpenRouter's auto-router
# picks the best model per prompt) or a specific id like "anthropic/claude-sonnet-4-5",
# "openai/gpt-4o", "google/gemini-2.5-flash", "moonshotai/kimi-k2".
# For other providers use their native model id (e.g. "claude-sonnet-4-5-20250929").
LLM_MODEL=openrouter/auto

# -----------------------------------------------------------------------------
# LLM Provider API Keys
# -----------------------------------------------------------------------------
# Supply the key for your chosen provider (at minimum).
# Multiple keys can be set so you can switch providers without editing the file.

# Anthropic API Key (for Claude models)
ANTHROPIC_API_KEY=***

# OpenAI API Key (for GPT models)
OPENAI_API_KEY=***

# Google API Key (for Gemini models)
GOOGLE_API_KEY=***

# OpenRouter API Key (for unified access to multiple LLM providers)
# OpenRouter lets you use any model via a single API. Model format: provider/model
# Examples: anthropic/claude-3-opus, openai/gpt-4-turbo, google/gemini-pro
# See available models at: https://openrouter.ai/models
OPENROUTER_API_KEY=***

# Optional: OpenRouter rate-limiting headers (helps avoid 429 errors)
# Set these to identify your app for higher rate limits
# OPENROUTER_REFERER=https://your-app.com
# OPENROUTER_TITLE=Your App Name

# OpenRouter API Key — OpenAI-compatible meta-provider giving access to many
# models (Claude, GPT, Gemini, Llama, Mistral, etc.) with a single key.
# Sign up at https://openrouter.ai/ and use model names like
# "anthropic/claude-sonnet-4-5" or "openai/gpt-4o" via LLM_MODEL / EVAL_JUDGE_MODEL.
OPENROUTER_API_KEY=

# Moonshot API Key (Kimi K2.5) — OpenAI-compatible LLM
MOONSHOT_API_KEY=

# -----------------------------------------------------------------------------
# Mesh Infrastructure
# -----------------------------------------------------------------------------

# Shared API key for sidecar <-> registry authentication
MESH_API_KEY=mesh-dev-key

# -----------------------------------------------------------------------------
# Registry Admin Credentials
# -----------------------------------------------------------------------------

# Admin username (seeded on first startup as an Administrator user)
ADMIN_USERNAME=admin

# Admin password (seeded on first startup - CHANGE THIS!)
ADMIN_PASSWORD=changeme

# -----------------------------------------------------------------------------
# Evaluation Judge Configuration
# -----------------------------------------------------------------------------
# These settings control which LLM is used to judge agent responses

# Provider for evaluation judge: openai, anthropic, google, openrouter, or moonshot
EVAL_JUDGE_PROVIDER=openrouter

# Model to use for judging. Pinned (not openrouter/auto) because the
# auto-router occasionally picks models with stricter content filters
# that return empty responses on safety-evaluation prompts (e.g. when
# the test case quotes a harmful prompt for the judge to score),
# breaking the JSON parser.
EVAL_JUDGE_MODEL=anthropic/claude-sonnet-4-5

# Temperature for judge responses (0.0 = deterministic)
EVAL_JUDGE_TEMPERATURE=0.0

# Maximum tokens for judge response
EVAL_JUDGE_MAX_TOKENS=1024

# -----------------------------------------------------------------------------
# Test Agent Configuration
# -----------------------------------------------------------------------------
# Settings for the test agent used during evaluation

# LLM provider for the test agent: openai, anthropic, google, openrouter, or moonshot
TEST_AGENT_PROVIDER=openrouter

# Model for the test agent (must match provider)
TEST_AGENT_MODEL=openrouter/auto
