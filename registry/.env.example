# =============================================================================
# Recursant Agent Registry - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values
# =============================================================================

# -----------------------------------------------------------------------------
# Flask Application
# -----------------------------------------------------------------------------

# Environment: development, production, or testing
FLASK_ENV=development

# Secret key for session signing (CHANGE IN PRODUCTION)
SECRET_KEY=dev-secret-key-change-in-production

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------

# Main database connection string
DATABASE_URL=postgresql://registry:registry@localhost:5432/registry

# Test database connection string (used when FLASK_ENV=testing)
TEST_DATABASE_URL=postgresql://registry:registry@localhost:5432/registry_test

# -----------------------------------------------------------------------------
# Redis Cache
# -----------------------------------------------------------------------------

REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# Admin Authentication (Web Interface)
# -----------------------------------------------------------------------------

# Admin username (seeded on first startup as an Administrator user)
ADMIN_USERNAME=admin

# Admin password (seeded on first startup - CHANGE THIS!)
ADMIN_PASSWORD=changeme

# JWT secret key for token signing (defaults to SECRET_KEY if not set)
JWT_SECRET_KEY=

# JWT token expiration in seconds (default: 24 hours)
JWT_ACCESS_TOKEN_EXPIRES=86400

# -----------------------------------------------------------------------------
# LLM Provider API Keys
# -----------------------------------------------------------------------------
# At least one API key is required for evaluation and security testing

# OpenAI API Key (for GPT models)
OPENAI_API_KEY=

# Anthropic API Key (for Claude models)
ANTHROPIC_API_KEY=

# Google API Key (for Gemini models)
GOOGLE_API_KEY=

# OpenRouter API Key — OpenAI-compatible meta-provider (one key, many models).
# Sign up at https://openrouter.ai/ and use model names like
# "anthropic/claude-sonnet-4-5" or "openai/gpt-4o" via EVAL_JUDGE_MODEL etc.
OPENROUTER_API_KEY=

# -----------------------------------------------------------------------------
# Evaluation Judge Configuration
# -----------------------------------------------------------------------------
# These settings control which LLM is used to judge agent responses

# Provider for evaluation judge: openai, anthropic, google, openrouter, or moonshot
EVAL_JUDGE_PROVIDER=openrouter

# Model to use for judging — for openrouter use "openrouter/auto" or a specific id
# like "anthropic/claude-sonnet-4-5", "openai/gpt-4o", "google/gemini-2.5-flash".
EVAL_JUDGE_MODEL=anthropic/claude-sonnet-4-5

# Temperature for judge responses (0.0 = deterministic)
EVAL_JUDGE_TEMPERATURE=0.0

# Maximum tokens for judge response
EVAL_JUDGE_MAX_TOKENS=1024

# -----------------------------------------------------------------------------
# Test Agent Configuration
# -----------------------------------------------------------------------------
# Settings for the test agent used during evaluation

# URL of the test agent (for docker compose, use http://test-agent:5001)
TEST_AGENT_URL=http://localhost:5001

# LLM provider for the test agent: openai, anthropic, google, openrouter, or moonshot
TEST_AGENT_PROVIDER=openrouter

# Model for the test agent (must match provider — see EVAL_JUDGE_MODEL above for openrouter ids)
TEST_AGENT_MODEL=openrouter/auto

# Moonshot (Kimi K2.5) — OpenAI-compatible LLM
MOONSHOT_API_KEY=
